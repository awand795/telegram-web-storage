{
  # TeleStore — FrankenPHP Caddyfile for production
  # Auto-generated by Docker build

  # Global settings
  auto_https off
  debug

  # Health check endpoint (no auth)
  @health {
    path /up.php
  }
  handle @health {
    root * /var/www/public
    php {path} /var/www/public
  }

  # Main app — all requests go through Octane
  handle {
    # Reverse proxy to Octane server running on port 8000
    reverse_proxy 127.0.0.1:8000 {
      # Graceful health checks
      health_uri /up.php
      health_interval 15s
      health_timeout 5s

      # Forward original client IP
      header_up X-Forwarded-For {remote_host}
      header_up X-Forwarded-Proto {scheme}
    }
  }
}
