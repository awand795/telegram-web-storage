{
    # TeleStore — FrankenPHP Caddyfile for production
    # FrankenPHP serves PHP directly via Octane
    auto_https off
}

# Listen on port 8000 (matches docker port mapping)
:8000 {
    root * /var/www/public
    php {
        resolve_root_symlink
    }
    
    # Health check
    @health {
        path /up.php
    }
    
    # Static files
    file_server
    
    # Log
    log {
        output file /var/www/storage/logs/caddy-access.log
    }
}
